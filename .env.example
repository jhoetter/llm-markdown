# Copy to .env and fill your keys before running provider integration tests.

# Agent streaming (stream_agent_turn / examples / integration tests)
# LLM_MARKDOWN_AGENT_BACKEND=openai
# LLM_MARKDOWN_AGENT_BACKEND=anthropic
# LLM_MARKDOWN_AGENT_BACKEND=openrouter
# Optional model override (defaults: gpt-4o-mini, claude-3-5-haiku-latest, openai/gpt-4o-mini)
# LLM_MARKDOWN_AGENT_MODEL=
# Reasoning policy: native | off | fallback
# (Calculator example uses fallback when unset so gpt-4o-mini shows planning deltas.)
# LLM_MARKDOWN_AGENT_REASONING_MODE=native

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Langfuse (optional observability)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
